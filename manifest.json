{
  "manifest_version": 3,
  "name": "Nemo Browser Controller",
  "version": "0.1.0",
  "description": "A browser controller extension. Lets an operator (or an LLM) navigate, read DOM, take screenshots, and inspect console + network like DevTools.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "debugger",
    "sidePanel",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Nemo Controller"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
